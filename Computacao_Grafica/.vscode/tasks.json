{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "Compilar OpenGL (Apenas Build)",
      "type": "shell",
      "command": "mkdir -p '${fileDirname}/output' && /usr/bin/g++ -g '${file}' -o '${fileDirname}/output/${fileBasenameNoExtension}' -lGL -lGLU -lglut",
      "group": "build",
      "problemMatcher": ["$gcc"],
      "detail": "Garante que a pasta output exista e compila o código C++ com OpenGL."
    },
    {
      "label": "Executar OpenGL Direto (F6)",
      "type": "shell",
      "command": "mkdir -p '${fileDirname}/output' && /usr/bin/g++ -g '${file}' -o '${fileDirname}/output/${fileBasenameNoExtension}' -lGL -lGLU -lglut && '${fileDirname}/output/${fileBasenameNoExtension}'",
      "group": {
        "kind": "test",
        "isDefault": true
      },
      "presentation": {
        "echo": true,
        "reveal": "always",
        "focus": true,
        "panel": "shared",
        "clear": true
      },
      "problemMatcher": []
    }
  ]
}