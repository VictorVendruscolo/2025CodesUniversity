{
  "version": "2.0.0",
  "tasks": [
    {
      "type": "shell",
      "label": "Compile OpenGL",
      "command": "g++",
      "args": [
        "-Wall",
        "-Wextra",
        "-g3",
        "${file}",
        "-o",
        "${fileDirname}/output/${fileBasenameNoExtension}",
        "-lglut",
        "-lGL",
        "-lGLU",
        "-lm"
      ],
      "options": {
        "cwd": "${fileDirname}"
      },
      "problemMatcher": ["$gcc"],
      "group": {
        "kind": "build",
        "isDefault": true
      }
    }
  ]
}
